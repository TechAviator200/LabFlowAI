# LabFlow AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Leave SUPABASE_* and LLM_API_KEY blank to run in demo mode (in-memory, heuristic parser).

# ── Supabase (leave blank → in-memory mock database) ──────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=labflow-uploads

# ── LLM (leave blank → heuristic fallback parser, no AI key needed) ───────────
# Supported providers: openai | azure | anthropic | local
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
# Generate a random value for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me-in-production

# Comma-separated allowed origins for CORS.
# Production: set to your Vercel frontend URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# Preload 3 demo workflows on startup (ELISA, RT-qPCR, Titration)
DEMO_MODE=true

# Force in-memory mock DB even when Supabase credentials are present (dev only)
USE_MOCK_DB=false
